# Secrets & Credentials
.env
.env.local
.env.*.local

# Python Environments & Cache
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# Package Managers
.uv/
uv.lock.bak

# Local Data & Outputs (Exclude real files, preserve directory structures via .gitkeep)
data/processed/*.md
data/processed/*.tex
!data/raw/.gitkeep
!data/processed/.gitkeep

# Logs & Generated Assets
logs/*.log
assets/*.png
assets/*.pdf
assets/*.svg
!assets/.gitkeep

# Notebooks
notebooks/.ipynb_checkpoints/
